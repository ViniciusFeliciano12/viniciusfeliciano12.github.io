# Copie este arquivo para .env.local e preencha com os valores do seu projeto Firebase.
# Encontre em: Firebase Console → Configurações do projeto → Seus apps → SDK → Config
#
# IMPORTANTE: .env.local nunca é commitado (ver .gitignore).
VITE_FIREBASE_API_KEY=COLE_AQUI
VITE_FIREBASE_AUTH_DOMAIN=COLE_AQUI
VITE_FIREBASE_PROJECT_ID=COLE_AQUI
VITE_FIREBASE_STORAGE_BUCKET=COLE_AQUI
VITE_FIREBASE_MESSAGING_SENDER_ID=COLE_AQUI
VITE_FIREBASE_APP_ID=COLE_AQUI
VITE_FIREBASE_MEASUREMENT_ID=COLE_AQUI
