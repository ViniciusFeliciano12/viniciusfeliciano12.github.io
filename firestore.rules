rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isMestre() {
      return exists(/databases/$(database)/documents/gm_users/$(request.auth.uid));
    }

    function campDoc(campanhaId) {
      return get(/databases/$(database)/documents/campanhas/$(campanhaId));
    }

    function isCampanhaGM(campanhaId) {
      return campDoc(campanhaId).data.gmId == request.auth.uid;
    }

    function isCampanhaParticipante(campanhaId) {
      return request.auth.uid in campDoc(campanhaId).data.jogadoresIds;
    }

    // Fichas: dono gerencia; GM da campanha lê e desvinculariza; participantes leem fichas da mesma campanha
    match /fichas/{fichaId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        isMestre() ||
        (resource.data.campanhaId != null && (
          isCampanhaGM(resource.data.campanhaId) ||
          isCampanhaParticipante(resource.data.campanhaId)
        ))
      );
      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        isMestre() ||
        (resource.data.campanhaId != null &&
         isCampanhaGM(resource.data.campanhaId)) ||
        (resource.data.campanhaId == null &&
         request.resource.data.campanhaId != null &&
         isCampanhaGM(request.resource.data.campanhaId))
      );
      allow delete: if request.auth != null && (
        resource.data.userId == request.auth.uid || isMestre()
      );
    }

    // gm_users: só leitura (escrita via console)
    match /gm_users/{userId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // users: qualquer autenticado lê; cada um escreve o próprio
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // campanhas
    match /campanhas/{campanhaId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
                       request.resource.data.gmId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.gmId == request.auth.uid ||
        isMestre() ||
        request.auth.uid in resource.data.jogadoresIds
      );
      allow delete: if request.auth != null && (
        resource.data.gmId == request.auth.uid || isMestre()
      );
    }

    // solicitações de entrada em campanhas
    match /campanhas/{campanhaId}/solicitacoes/{uid} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        campDoc(campanhaId).data.gmId == request.auth.uid ||
        isMestre()
      );
      allow create: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null && (
        request.auth.uid == uid ||
        campDoc(campanhaId).data.gmId == request.auth.uid ||
        isMestre()
      );
      allow update: if false;
    }
  }
}
