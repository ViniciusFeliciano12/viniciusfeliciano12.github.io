rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isMestre() {
      return exists(/databases/$(database)/documents/gm_users/$(request.auth.uid));
    }

    function campDoc(campanhaId) {
      return get(/databases/$(database)/documents/campanhas/$(campanhaId));
    }

    function isCampanhaGM(campanhaId) {
      return campDoc(campanhaId).data.gmId == request.auth.uid;
    }

    function isCampanhaParticipante(campanhaId) {
      return campDoc(campanhaId).data.jogadoresIds.hasAny([request.auth.uid]);
    }

    // Fichas: dono gerencia; GM da campanha lê e desvincula; participantes leem fichas da mesma campanha
    match /fichas/{fichaId} {
      allow read: if request.auth != null && (
        resource.data.get('userId', '') == request.auth.uid ||
        isMestre() ||
        (resource.data.get('campanhaId', null) != null && (
          isCampanhaGM(resource.data.get('campanhaId', '')) ||
          isCampanhaParticipante(resource.data.get('campanhaId', ''))
        ))
      );

      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid;

      allow update: if request.auth != null &&
                    request.resource.data.get('userId', '') == resource.data.get('userId', '') && (
        // 1. O próprio dono da ficha pode editar (inclusive vincular/desvincular sua própria ficha)
        resource.data.get('userId', '') == request.auth.uid ||
        // 2. Mestre administrador global
        isMestre() ||
        // 3. O GM da campanha atual pode editar/atualizar os dados normalmente
        (resource.data.get('campanhaId', null) != null &&
         isCampanhaGM(resource.data.get('campanhaId', ''))) ||
        // 4. O GM vincula uma ficha à sua campanha no momento em que aceita o jogador (via batch)
        (resource.data.get('campanhaId', null) == null &&
         request.resource.data.get('campanhaId', null) != null &&
         isCampanhaGM(request.resource.data.campanhaId) &&
         getAfter(/databases/$(database)/documents/campanhas/$(request.resource.data.campanhaId)).data.jogadoresIds.hasAny([resource.data.get('userId', '')]))
      );

      allow delete: if request.auth != null && (
        resource.data.get('userId', '') == request.auth.uid || isMestre()
      );
    }

    // gm_users: só leitura (escrita via console)
    match /gm_users/{userId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // users: qualquer autenticado lê; cada um escreve o próprio
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // campanhas
    match /campanhas/{campanhaId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
                       request.resource.data.gmId == request.auth.uid;
      allow update: if request.auth != null && (
        // GM e Mestre administrador gerenciam tudo
        resource.data.gmId == request.auth.uid ||
        isMestre() ||
        // Jogador pode APENAS se remover da campanha (sair):
        //   - precisa estar em jogadoresIds antes
        //   - após o update, não está mais em jogadoresIds
        //   - campos críticos (gmId, nome, sistema) não mudam
        (
          resource.data.jogadoresIds.hasAny([request.auth.uid]) &&
          !request.resource.data.jogadoresIds.hasAny([request.auth.uid]) &&
          request.resource.data.get('gmId', '') == resource.data.get('gmId', '') &&
          request.resource.data.get('nome', '') == resource.data.get('nome', '') &&
          request.resource.data.get('sistema', '') == resource.data.get('sistema', '')
        )
      );
      allow delete: if request.auth != null && (
        resource.data.gmId == request.auth.uid || isMestre()
      );
    }

    // solicitações de entrada em campanhas
    match /campanhas/{campanhaId}/solicitacoes/{uid} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        campDoc(campanhaId).data.gmId == request.auth.uid ||
        isMestre()
      );
      allow create: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null && (
        request.auth.uid == uid ||
        campDoc(campanhaId).data.gmId == request.auth.uid ||
        isMestre()
      );
      allow update: if false;
    }
  }
}
